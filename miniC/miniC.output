    "-" (275) 70 73
    "*" (276) 71
    "/" (277) 72
    "=" (278) 9 34 52
    ";" (279) 5 27 29 35 36 37 38 45 47 48 49 50
    "(" (280) 14 40 41 43 45 47 49 50 74 77
    ")" (281) 14 40 41 43 45 47 49 50 74 77
    "{" (282) 22
    "}" (283) 22
    "," (284) 7 17 32 54 58 61
    "==" (285) 64
    "!=" (286) 63
    ">" (287) 65
    ">=" (288) 66
    "<" (289) 67
    "<=" (290) 68
    UMINUS (291)
    NOELSE (292)



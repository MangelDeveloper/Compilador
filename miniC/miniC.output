Grammar

    0 $accept: program $end

    1 $@1: %empty

    2 program: $@1 global_declarations function_list

    3 global_declarations: %empty
    4                    | global_declarations global_declaration

    5 global_declaration: VAR tipo global_id_list ";"

    6 global_id_list: global_id_decl
    7               | global_id_list "," global_id_decl

    8 global_id_decl: IDE
    9               | IDE "=" NUM

   10 function_list: function
   11              | function_list function

   12 $@2: %empty

   13 $@3: %empty

   14 function: return_function IDE "(" $@2 param_list ")" $@3 block

   15 param_list: %empty
   16           | param_decl
   17           | param_list "," param_decl

   18 param_decl: INT IDE

   19 return_function: INT
   20                | VOI

   21 $@4: %empty

   22 block: "{" $@4 body "}"

   23 body: body declaration
   24     | body statement
   25     | %empty

   26 $@5: %empty

   27 declaration: VAR $@5 tipo id_list ";"

   28 $@6: %empty

   29 declaration: CON $@6 tipo id_list ";"

   30 tipo: INT

   31 id_list: id_decl
   32        | id_list "," id_decl

   33 id_decl: IDE
   34        | IDE "=" expression

   35 statement: asignation ";"
   36          | call_function ";"
   37          | RET expression ";"
   38          | RET ";"
   39          | block
   40          | IF "(" expression ")" statement
   41          | IF "(" expression ")" statement ELS statement

   42 $@7: %empty

   43 statement: WHI $@7 "(" expression ")" statement

   44 $@8: %empty

   45 statement: DO $@8 statement WHI "(" expression ")" ";"

   46 $@9: %empty

   47 statement: FOR $@9 "(" asignation ";" expression ";" asignation ")" statement
   48          | BRK ";"
   49          | PRI "(" print_list ")" ";"
   50          | REA "(" read_list ")" ";"

   51 $@10: %empty

   52 asignation: IDE $@10 "=" expression

   53 print_list: print_item
   54           | print_list "," print_item

   55 print_item: expression
   56           | CAD

   57 read_list: IDE
   58          | read_list "," IDE

   59 arg_list: %empty
   60         | expression
   61         | arg_list "," expression

   62 expression: call_function
   63           | expression "!=" expression
   64           | expression "==" expression
   65           | expression ">" expression
   66           | expression ">=" expression
   67           | expression "<" expression
   68           | expression "<=" expression
   69           | expression "+" expression
   70           | expression "-" expression
   71           | expression "*" expression
   72           | expression "/" expression
   73           | "-" expression
   74           | "(" expression ")"
   75           | NUM
   76           | IDE

   77 call_function: IDE "(" arg_list ")"



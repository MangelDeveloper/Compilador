void main() {
    const int a = 10, b = 0;
    print ("Inicio del programa\n");
    var int c = 5+2-2;
    if (a) print ("a","\n");
    else if (b) print ("No a y b\n");
    else while (c) {
        var int a = 0;
        var int d = 4+3*5;
        print("c = ",c,"\n");
        c = c-2+1;
        print(d+1,"\n");
    }
    print("El valor de a es: ",a,"\n");
